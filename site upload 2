<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>3 G's Woodworking</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Libre+Baskerville:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --wood-dark: #2C1810;
    --wood-mid: #6B3A2A;
    --wood-warm: #A0522D;
    --wood-light: #C8956C;
    --wood-pale: #F2E8DC;
    --cream: #FAF6F0;
    --charcoal: #1A1A18;
    --text-muted: #6B6560;
    --gold: #B8860B;
    --gold-light: #D4A843;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--charcoal);
    overflow-x: hidden;
  }

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(250, 246, 240, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(107, 58, 42, 0.12);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--wood-dark);
    letter-spacing: 0.01em;
  }

  .nav-logo span {
    color: var(--wood-warm);
    font-style: italic;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--wood-dark);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--wood-warm); }

  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 6rem 5rem;
    background: var(--cream);
    position: relative;
  }

  .hero-left::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 10%;
    bottom: 10%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--wood-light), transparent);
  }

  .hero-tagline {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--wood-warm);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-tagline::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--wood-warm);
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1.1;
    color: var(--wood-dark);
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .hero-title em {
    font-style: italic;
    color: var(--wood-warm);
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 38ch;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.25rem;
    background: var(--wood-dark);
    color: var(--wood-pale);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.25s, transform 0.2s;
    width: fit-content;
  }

  .hero-cta:hover {
    background: var(--wood-mid);
    transform: translateY(-2px);
  }

  .hero-cta-arrow { font-size: 1.1rem; transition: transform 0.2s; }
  .hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }

  .hero-right {
    background: var(--wood-dark);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 4rem;
    overflow: hidden;
  }

  .hero-wood-texture {
    position: absolute;
    inset: 0;
    opacity: 0.07;
    background-image: repeating-linear-gradient(92deg, transparent, transparent 3px, rgba(200,149,108,0.4) 3px, rgba(200,149,108,0.4) 4px), repeating-linear-gradient(180deg, transparent, transparent 40px, rgba(200,149,108,0.15) 40px, rgba(200,149,108,0.15) 41px);
  }

  .hero-ring {
    position: absolute;
    top: 15%; right: 15%;
    width: 280px; height: 280px;
    border-radius: 50%;
    border: 1px solid rgba(200,149,108,0.2);
  }

  .hero-ring::before {
    content: '';
    position: absolute;
    inset: 20px;
    border-radius: 50%;
    border: 1px solid rgba(200,149,108,0.15);
  }

  .hero-ring::after {
    content: '';
    position: absolute;
    inset: 40px;
    border-radius: 50%;
    border: 1px solid rgba(200,149,108,0.1);
  }

  .hero-gen-badge {
    position: absolute;
    top: 4rem; left: 4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gen-dot {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(242,232,220,0.6);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .gen-dot::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--wood-light);
    opacity: 0.7;
  }

  .hero-quote { position: relative; z-index: 2; }

  .hero-quote blockquote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.5;
    color: var(--wood-pale);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .hero-quote cite {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--wood-light);
    font-style: normal;
  }

  .gen-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: var(--wood-mid);
  }

  .gen-item {
    background: var(--wood-mid);
    padding: 2rem 3rem;
    text-align: center;
    position: relative;
  }

  .gen-item + .gen-item::before {
    content: '';
    position: absolute;
    left: 0; top: 20%; bottom: 20%;
    width: 1px;
    background: rgba(242,232,220,0.2);
  }

  .gen-number {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--wood-pale);
    opacity: 0.25;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .gen-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--wood-light);
    margin-bottom: 0.5rem;
  }

  .gen-desc {
    font-size: 0.9rem;
    color: rgba(242,232,220,0.7);
    line-height: 1.5;
    font-weight: 300;
  }

  section { padding: 7rem 5rem; }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--wood-warm);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 1.5rem; height: 1px;
    background: var(--wood-warm);
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--wood-dark);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .portfolio-section { background: white; }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .portfolio-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: var(--wood-pale);
  }

  .portfolio-card:first-child { grid-column: 1 / 3; }

  .portfolio-img {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--wood-dark);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .portfolio-card:first-child .portfolio-img { aspect-ratio: 16/9; }

  .wood-grain-placeholder {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    background-image: repeating-linear-gradient(95deg, transparent, transparent 2px, rgba(200,149,108,0.5) 2px, rgba(200,149,108,0.5) 3px);
  }

  .placeholder-label {
    position: relative;
    z-index: 2;
    text-align: center;
    color: rgba(242,232,220,0.5);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .placeholder-icon { font-size: 2.5rem; margin-bottom: 0.5rem; opacity: 0.4; }

  .portfolio-info {
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .portfolio-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--wood-dark);
  }

  .portfolio-material {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-top: 0.2rem;
  }

  .portfolio-arrow {
    width: 36px; height: 36px;
    border: 1px solid var(--wood-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--wood-warm);
    font-size: 1rem;
    transition: all 0.2s;
  }

  .portfolio-card:hover .portfolio-arrow {
    background: var(--wood-dark);
    border-color: var(--wood-dark);
    color: var(--wood-pale);
  }

  .about-section {
    background: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    padding: 7rem 5rem;
  }

  .about-visual { position: relative; }

  .about-main-img {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--wood-dark);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-accent-box {
    position: absolute;
    bottom: -2rem; right: -2rem;
    width: 55%;
    aspect-ratio: 1;
    background: var(--wood-warm);
    z-index: -1;
  }

  .about-stat {
    position: absolute;
    bottom: 2rem; left: -2rem;
    background: var(--cream);
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--wood-warm);
    box-shadow: 0 8px 32px rgba(44,24,16,0.15);
  }

  .about-stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--wood-dark);
    line-height: 1;
  }

  .about-stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  .about-text p {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-weight: 300;
  }

  .about-text p strong { color: var(--wood-dark); font-weight: 500; }

  .about-values {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-value { display: flex; align-items: flex-start; gap: 1rem; }

  .value-icon {
    width: 32px; height: 32px;
    background: var(--wood-pale);
    border: 1px solid var(--wood-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--wood-warm);
    font-size: 0.9rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .value-text strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--wood-dark);
    margin-bottom: 0.2rem;
  }

  .value-text span { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }

  .contact-section {
    background: var(--wood-dark);
    padding: 7rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    position: relative;
    overflow: hidden;
  }

  .contact-bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(200,149,108,1) 60px, rgba(200,149,108,1) 61px), repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(200,149,108,1) 60px, rgba(200,149,108,1) 61px);
  }

  .contact-left .section-title { color: var(--wood-pale); }
  .contact-left .section-label { color: var(--wood-light); }
  .contact-left .section-label::before { background: var(--wood-light); }

  .contact-info { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: rgba(242,232,220,0.7);
    font-size: 0.9rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .contact-item-icon {
    width: 36px; height: 36px;
    border: 1px solid rgba(200,149,108,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--wood-light);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .contact-item strong {
    display: block;
    color: var(--wood-pale);
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }

  .contact-form { position: relative; z-index: 2; display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .form-group label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--wood-light);
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(200,149,108,0.25);
    color: var(--wood-pale);
    padding: 0.85rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder { color: rgba(200,149,108,0.35); }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--wood-light);
    background: rgba(255,255,255,0.07);
  }

  .form-group textarea { resize: vertical; min-height: 120px; }
  .form-group select option { background: var(--wood-dark); color: var(--wood-pale); }

  .submit-btn {
    padding: 1.1rem 2.5rem;
    background: var(--wood-warm);
    color: var(--wood-pale);
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, transform 0.2s;
    width: 100%;
    margin-top: 0.5rem;
  }

  .submit-btn:hover { background: var(--wood-light); transform: translateY(-2px); }

  footer {
    background: #110D0A;
    padding: 2.5rem 5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--wood-pale); opacity: 0.6; }
  .footer-copy { font-size: 0.75rem; color: rgba(200,149,108,0.4); letter-spacing: 0.05em; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-left > * { animation: fadeUp 0.7s ease both; }
  .hero-left > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-left > *:nth-child(2) { animation-delay: 0.25s; }
  .hero-left > *:nth-child(3) { animation-delay: 0.4s; }
  .hero-left > *:nth-child(4) { animation-delay: 0.55s; }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">3 <span>G's</span> Woodworking</div>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<section class="hero" id="home">
  <div class="hero-left">
    <div class="hero-tagline">Three Generations. One Craft.</div>
    <h1 class="hero-title">Built by hand.<br><em>Built to last.</em></h1>
    <p class="hero-sub">Custom hardwood furniture crafted across three generations of family tradition. Every piece tells a story — yours and ours.</p>
    <a href="#portfolio" class="hero-cta">View our work <span class="hero-cta-arrow">→</span></a>
  </div>
  <div class="hero-right">
    <div class="hero-wood-texture"></div>
    <div class="hero-ring"></div>
    <div class="hero-gen-badge">
      <div class="gen-dot">Grandfather</div>
      <div class="gen-dot">Father</div>
      <div class="gen-dot">Son</div>
    </div>
    <div class="hero-quote">
      <blockquote>"Wood remembers the hands that shaped it."</blockquote>
      <cite>— The 3 G's philosophy</cite>
    </div>
  </div>
</section>

<div class="gen-strip">
  <div class="gen-item">
    <div class="gen-number">I</div>
    <div class="gen-label">The Foundation</div>
    <div class="gen-desc">Decades of traditional joinery and a respect for the grain that runs through everything we build.</div>
  </div>
  <div class="gen-item">
    <div class="gen-number">II</div>
    <div class="gen-label">The Bridge</div>
    <div class="gen-desc">Expanding into custom commissions, blending classic technique with modern design sensibility.</div>
  </div>
  <div class="gen-item">
    <div class="gen-number">III</div>
    <div class="gen-label">The Future</div>
    <div class="gen-desc">Bringing fresh vision to timeless craft — and carrying the family legacy forward one piece at a time.</div>
  </div>
</div>

<section class="portfolio-section" id="portfolio">
  <div class="portfolio-header">
    <div>
      <div class="section-label">Our work</div>
      <h2 class="section-title">Built for real life,<br>made to be passed down.</h2>
    </div>
    <a href="#contact" style="font-size:0.85rem; color:var(--wood-warm); text-decoration:none; letter-spacing:0.08em; border-bottom: 1px solid var(--wood-light); padding-bottom:2px;">Commission a piece →</a>
  </div>
  <div class="portfolio-grid">
    <div class="portfolio-card">
      <div class="portfolio-img">
        <div class="wood-grain-placeholder"></div>
        <div class="placeholder-label">
          <div class="placeholder-icon">🪵</div>
          <div>Add your hero photo here</div>
        </div>
      </div>
      <div class="portfolio-info">
        <div>
          <div class="portfolio-name">Heirloom Dining Table</div>
          <div class="portfolio-material">White Oak · Mortise & Tenon joinery</div>
        </div>
        <div class="portfolio-arrow">→</div>
      </div>
    </div>
    <div class="portfolio-card">
      <div class="portfolio-img">
        <div class="wood-grain-placeholder"></div>
        <div class="placeholder-label">
          <div class="placeholder-icon">🪑</div>
          <div>Add photo</div>
        </div>
      </div>
      <div class="portfolio-info">
        <div>
          <div class="portfolio-name">Live Edge Coffee Table</div>
          <div class="portfolio-material">Black Walnut · Natural slab</div>
        </div>
        <div class="portfolio-arrow">→</div>
      </div>
    </div>
    <div class="portfolio-card">
      <div class="portfolio-img">
        <div class="wood-grain-placeholder"></div>
        <div class="placeholder-label">
          <div class="placeholder-icon">🚪</div>
          <div>Add photo</div>
        </div>
      </div>
      <div class="portfolio-info">
        <div>
          <div class="portfolio-name">Custom Cabinetry</div>
          <div class="portfolio-material">Cherry · Dovetail drawers</div>
        </div>
        <div class="portfolio-arrow">→</div>
      </div>
    </div>
    <div class="portfolio-card">
      <div class="portfolio-img">
        <div class="wood-grain-placeholder"></div>
        <div class="placeholder-label">
          <div class="placeholder-icon">🛏</div>
          <div>Add photo</div>
        </div>
      </div>
      <div class="portfolio-info">
        <div>
          <div class="portfolio-name">Platform Bed Frame</div>
          <div class="portfolio-material">Hard Maple · Hand-planed finish</div>
        </div>
        <div class="portfolio-arrow">→</div>
      </div>
    </div>
  </div>
</section>

<div class="about-section" id="about">
  <div class="about-visual">
    <div class="about-main-img">
      <div class="wood-grain-placeholder"></div>
      <div style="position:relative;z-index:2;text-align:center;color:rgba(242,232,220,0.4);font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;">Add shop or family photo</div>
